{
  "name": "n8n-desk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "build:electron:ts": "node scripts/build-electron.mjs",
    "dev:electron": "pnpm build:electron:ts && concurrently -k \"vite\" \"electron .\"",
    "build:electron": "pnpm build && pnpm build:electron:ts && electron-forge package",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.{ts,vue}' 'electron/**/*.ts'"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.2.1",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/keyboard": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@ionic/vue": "^8.0.0",
    "@ionic/vue-router": "^8.0.0",
    "ionicons": "^7.4.0",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^2.2.0",
    "vue": "^3.5.0",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@electron-forge/cli": "^7.0.0",
    "@electron-forge/maker-zip": "^7.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.0.0",
    "jsdom": "^25.0.0",
    "sass": "^1.80.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.0.0"
  }
}
