    "highlight.js": "^11.11.0",
    "ionicons": "^7.4.0",
    "js-yaml": "^4.1.0",
    "langchain": "^0.3.0",
    "lucide-vue-next": "^0.577.0",
    "mammoth": "^1.8.0",
    "markdown-it": "^14.1.0",
    "markdown-it-link-attributes": "^4.0.1",
    "papaparse": "^5.4.0",
    "pdf-parse": "1.1.1",
    "pinia": "^2.2.0",
