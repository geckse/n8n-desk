    white-space: nowrap;
    transition: background var(--transition);
  }

  .waitlist-form button:hover:not(:disabled) { background: var(--accent-hover); }
  .waitlist-form button:disabled { opacity: 0.7; cursor: not-allowed; }

  /* --- Hero screenshot wrapper (cloud + frame) --- */
  .hero-screenshot-wrap {
    position: relative;
    max-width: 960px;
    margin: 0 auto;
    overflow: visible;
  }

  .hero-screenshot {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    box-shadow: 0 40px 80px hsla(7, 100%, 68%, 0.06), 0 0 0 1px var(--border-subtle);
  }

  .screenshot-chrome {
    background: var(--neutral-900);
    padding: 12px 16px;
    display: flex;
    gap: 8px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-red    { background: hsl(355, 83%, 52%); }
  .dot-yellow { background: hsl(46, 100%, 50%); }
  .dot-green  { background: hsl(147, 60%, 50%); }

  .screenshot-carousel {
    position: relative;
