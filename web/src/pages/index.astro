---
// n8n-desk Waitlist Landing Page
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>n8n-desk — Bringing n8n to your Machine</title>
  <meta name="description" content="n8n-desk is a desktop companion app for n8n. Chat with agents, build workflows, and work with local files — all from your machine." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- Nav -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="#" class="nav-logo">n8n-desk</a>
      <div class="nav-links">
        <a href="#modes">Modes</a>
        <a href="#features">Features</a>
        <a href="#hero" class="nav-cta">Join Waitlist</a>
      </div>
      <button class="nav-mobile-toggle" aria-label="Open menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </nav>

  <!-- Hero -->
  <section id="hero" class="hero">
    <div class="hero-dot-grid" aria-hidden="true"></div>
    <p class="hero-label">COMING SOON</p>
    <h1 class="hero-title">n8n-desk</h1>
    <p class="hero-tagline">Bringing n8n to your Machine</p>

    <form id="waitlist-form" class="waitlist-form" novalidate>
      <input
        type="email"
        id="waitlist-email"
        placeholder="Enter your email"
        autocomplete="email"
        required
      />
      <button type="submit">Join the Waitlist</button>
    </form>

    <div class="hero-screenshot-wrap">
      <!-- Floating word clouds per mode -->
      <div class="cloud cloud-active" data-cloud="0">
        <span class="cloud-tag" style="--left:-8%;--top:8%;--delay:0ms;--drift:10px;--dur:4.2s">Native Chat-Hub</span>
        <span class="cloud-tag" style="--left:88%;--top:5%;--delay:100ms;--drift:-8px;--dur:3.8s">Stream Responses</span>
        <span class="cloud-tag" style="--left:-5%;--top:85%;--delay:200ms;--drift:12px;--dur:4.5s">Agent Sidebar</span>
        <span class="cloud-tag" style="--left:90%;--top:80%;--delay:300ms;--drift:-14px;--dur:3.6s">Multi-Agent</span>
        <span class="cloud-tag" style="--left:-10%;--top:48%;--delay:150ms;--drift:8px;--dur:4s">Session History</span>
      </div>
      <div class="cloud" data-cloud="1">
        <span class="cloud-tag" style="--left:-6%;--top:10%;--delay:0ms;--drift:-9px;--dur:4.4s">Local Files</span>
        <span class="cloud-tag" style="--left:86%;--top:3%;--delay:100ms;--drift:11px;--dur:3.7s">Deep Agents SDK</span>
        <span class="cloud-tag" style="--left:-8%;--top:82%;--delay:200ms;--drift:13px;--dur:4.1s">Workflow as Tools</span>
        <span class="cloud-tag" style="--left:92%;--top:78%;--delay:300ms;--drift:-8px;--dur:3.9s">Read &amp; Write</span>
        <span class="cloud-tag" style="--left:91%;--top:45%;--delay:150ms;--drift:10px;--dur:4.3s">Project Folders</span>
      </div>
      <div class="cloud" data-cloud="2">
        <span class="cloud-tag" style="--left:-7%;--top:6%;--delay:0ms;--drift:10px;--dur:3.9s">n8n MCP</span>
        <span class="cloud-tag" style="--left:89%;--top:10%;--delay:100ms;--drift:-12px;--dur:4.2s">Build Workflows</span>
        <span class="cloud-tag" style="--left:-9%;--top:88%;--delay:200ms;--drift:-9px;--dur:4.5s">Validate &amp; Deploy</span>
        <span class="cloud-tag" style="--left:87%;--top:82%;--delay:300ms;--drift:13px;--dur:3.6s">Node Discovery</span>
        <span class="cloud-tag" style="--left:-6%;--top:50%;--delay:150ms;--drift:-10px;--dur:4.1s">Publish &amp; Execute</span>
      </div>

      <div class="hero-screenshot">
        <div class="screenshot-chrome">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
        </div>
        <div class="screenshot-carousel">
          <div class="screenshot-slide active" data-slide="0">
            <div class="screenshot-body">
              <p class="screenshot-placeholder">Chat Mode Screenshot</p>
            </div>
          </div>
          <div class="screenshot-slide" data-slide="1">
            <div class="screenshot-body">
              <p class="screenshot-placeholder">Cowork Mode Screenshot</p>
            </div>
          </div>
          <div class="screenshot-slide" data-slide="2">
            <div class="screenshot-body">
              <p class="screenshot-placeholder">Workflow Mode Screenshot</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Three Modes -->
  <section id="modes" class="modes">
    <h2 class="section-title">Three Modes. One App.</h2>

    <!-- iOS-style pill segment control -->
    <div class="mode-segment">
      <div class="mode-segment-track">
        <div class="mode-segment-pill" data-active="0"></div>
        <button class="mode-segment-btn active" data-index="0">Chat</button>
        <button class="mode-segment-btn" data-index="1">Cowork</button>
        <button class="mode-segment-btn" data-index="2">Workflow</button>
      </div>
    </div>

    <div class="modes-grid">

      <div class="mode-card active" data-mode="0">
        <div class="mode-icon">
          <!-- MessageSquare -->
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <h3 class="mode-title">Chat</h3>
        <p class="mode-desc">Use your Chat-Hub Agents directly from the desktop. A thin client to n8n's conversational AI assistants.</p>
      </div>

      <div class="mode-card" data-mode="1">
        <div class="mode-icon">
          <!-- FolderOpen -->
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        </div>
        <h3 class="mode-title">Cowork</h3>
        <p class="mode-desc">Work within local project folders and files. Your AI agent reads, writes, and organizes — powered by n8n workflows as tools.</p>
      </div>

      <div class="mode-card" data-mode="2">
        <div class="mode-icon">
          <!-- GitBranch -->
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg>
        </div>
        <h3 class="mode-title">Workflow</h3>
        <p class="mode-desc">Build, validate, and manage n8n workflows conversationally using the official n8n MCP server.</p>
      </div>

    </div>
  </section>

  <!-- Features -->
  <section id="features" class="features">
    <h2 class="section-title">Built for Power Users</h2>
    <div class="features-grid">

      <div class="feature">
        <div class="feature-icon">
          <!-- Monitor -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <div class="feature-text">
          <h4>Desktop-Native</h4>
          <p>A dedicated app that talks directly to your n8n instances. No browser tab required.</p>
        </div>
      </div>

      <div class="feature">
        <div class="feature-icon">
          <!-- Layers -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
        </div>
        <div class="feature-text">
          <h4>Multi-Instance Support</h4>
          <p>Connect and switch between multiple n8n instances — production, staging, local dev.</p>
        </div>
      </div>

      <div class="feature">
        <div class="feature-icon">
          <!-- Plug -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22v-5"/><path d="M9 8V2"/><path d="M15 8V2"/><path d="M18 8v5a6 6 0 0 1-6 6v0a6 6 0 0 1-6-6V8z"/></svg>
        </div>
        <div class="feature-text">
          <h4>Official n8n MCP</h4>
          <p>Direct integration via n8n's Model Context Protocol server for workflow management.</p>
        </div>
      </div>

      <div class="feature">
        <div class="feature-icon">
          <!-- BrainCircuit -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4.5a2.5 2.5 0 0 0-4.96-.46 2.5 2.5 0 0 0-1.98 3 2.5 2.5 0 0 0 1.32 4.24 3 3 0 0 0 .34 5.58 2.5 2.5 0 0 0 2.96 3.08A2.5 2.5 0 0 0 12 21.5V12"/><path d="M12 4.5a2.5 2.5 0 0 1 4.96-.46 2.5 2.5 0 0 1 1.98 3 2.5 2.5 0 0 1-1.32 4.24 3 3 0 0 1-.34 5.58 2.5 2.5 0 0 1-2.96 3.08A2.5 2.5 0 0 1 12 21.5"/><circle cx="12" cy="8" r="1"/><circle cx="12" cy="16" r="1"/><circle cx="8" cy="12" r="1"/><circle cx="16" cy="12" r="1"/></svg>
        </div>
        <div class="feature-text">
          <h4>Anthropic SDK + Open-Source Models</h4>
          <p>Supports the official Anthropic SDK, plus any LangChain-compatible model via Deep Agents.</p>
        </div>
      </div>

      <div class="feature">
        <div class="feature-icon">
          <!-- Server -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
        </div>
        <div class="feature-text">
          <h4>Local Models via Ollama</h4>
          <p>Run fully offline with Ollama or any OpenAI-compatible endpoint. No API key required.</p>
        </div>
      </div>

      <div class="feature">
        <div class="feature-icon">
          <!-- ShieldCheck -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        </div>
        <div class="feature-text">
          <h4>No Local Code Execution</h4>
          <p>n8n becomes your execution layer. Your machine stays clean — workflows run on your instance.</p>
        </div>
      </div>

      <div class="feature">
        <div class="feature-icon">
          <!-- ScrollText -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 21h12a2 2 0 0 0 2-2v-2H10v2a2 2 0 1 1-4 0V5a2 2 0 1 0-4 0v3h4"/><path d="M19 17V5a2 2 0 0 0-2-2H4"/><path d="M15 8h-5"/><path d="M15 12h-5"/></svg>
        </div>
        <div class="feature-text">
          <h4>Full Audit Trails</h4>
          <p>Every agent action flows through n8n, giving you complete execution logs and history.</p>
        </div>
      </div>

      <div class="feature">
        <div class="feature-icon">
          <!-- Lock -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <div class="feature-text">
          <h4>Secure by Design</h4>
          <p>Tokens in the OS keychain. OAuth2 PKCE for all connections. No secrets in config files.</p>
        </div>
      </div>

      <div class="feature">
        <div class="feature-icon">
          <!-- WifiOff -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="1" x2="23" y2="23"/><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"/><path d="M10.71 5.05A16 16 0 0 1 22.56 9"/><path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>
        </div>
        <div class="feature-text">
          <h4>Works Offline</h4>
          <p>Browse past sessions, work with local models, and access files — even without a connection.</p>
        </div>
      </div>

      <div class="feature">
        <div class="feature-icon">
          <!-- Smartphone -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
        </div>
        <div class="feature-text">
          <h4>Cross-Platform Ready</h4>
          <p>Built with Ionic + Capacitor. Desktop first, mobile follows. One codebase, every platform.</p>
        </div>
      </div>

      <div class="feature">
        <div class="feature-icon">
          <!-- KeyRound -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 18v3c0 .6.4 1 1 1h4v-3h3v-3h2l1.4-1.4a6.5 6.5 0 1 0-4-4Z"/><circle cx="16.5" cy="7.5" r=".5"/></svg>
        </div>
        <div class="feature-text">
          <h4>OAuth2 Login via n8n</h4>
          <p>Sign in with your n8n account. Role-based access — chat users see Chat, admins see everything.</p>
        </div>
      </div>

      <div class="feature">
        <div class="feature-icon">
          <!-- MessageCircle -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
        </div>
        <div class="feature-text">
          <h4>Conversational Workflow Builder</h4>
          <p>Describe what you want in plain language. The agent builds, validates, and deploys the workflow.</p>
        </div>
      </div>

    </div>
  </section>

  <!-- Open Source Disclaimer -->
  <section class="opensource">
    <div class="opensource-inner">
      <div class="opensource-icon">
        <!-- Heart + Code -->
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
      </div>
      <h2 class="opensource-title">Open Source. Community Driven.</h2>
      <p class="opensource-desc">n8n-desk is an independent, open-source community project. It is <strong>not officially affiliated with, endorsed by, or maintained by n8n GmbH or n8n.io.</strong> It builds on n8n's open platform and public APIs.</p>
      <div class="opensource-badges">
        <a href="https://github.com" target="_blank" rel="noopener" class="opensource-badge">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View on GitHub
        </a>
        <span class="opensource-badge opensource-badge--license">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          MIT License
        </span>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-inner">
      <span class="footer-logo">n8n-desk</span>
      <div class="footer-links">
        <a href="https://n8n.io" target="_blank" rel="noopener">n8n.io</a>
        <a href="https://github.com" target="_blank" rel="noopener" aria-label="GitHub">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>n8n-desk is an independent project built on top of n8n's open platform. Built for builders.</p>
    </div>
  </footer>

  <!-- Success Modal -->
  <div id="modal-success" class="modal-overlay" aria-hidden="true">
    <div class="modal">
      <div class="modal-icon modal-icon--success">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      </div>
      <h3>You're on the list!</h3>
      <p>We'll notify you when n8n-desk is ready for early access.</p>
      <button class="modal-close" data-dismiss="modal">Got it</button>
    </div>
  </div>

  <!-- Error Modal -->
  <div id="modal-error" class="modal-overlay" aria-hidden="true">
    <div class="modal">
      <div class="modal-icon modal-icon--error">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
      </div>
      <h3>Something went wrong</h3>
      <p id="modal-error-message">Please try again in a moment.</p>
      <button class="modal-close" data-dismiss="modal">Close</button>
    </div>
  </div>

  <script is:inline>
    // ------- CONFIG -------
    // TODO: Replace with your actual n8n webhook URL
    var WEBHOOK_URL = 'https://your-n8n-instance.com/webhook/waitlist';

    // ------- FORM SUBMISSION -------
    var form = document.getElementById('waitlist-form');
    var emailInput = document.getElementById('waitlist-email');

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var email = emailInput.value.trim();

      if (!email || !isValidEmail(email)) {
        emailInput.classList.add('input-error');
        emailInput.focus();
        return;
      }

      emailInput.classList.remove('input-error');
      var btn = form.querySelector('button[type="submit"]');
      var originalText = btn.textContent;
      btn.textContent = 'Sending...';
      btn.disabled = true;

      fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email, ts: new Date().toISOString() }),
      })
        .then(function (res) {
          if (!res.ok) throw new Error('HTTP ' + res.status);
          emailInput.value = '';
          showModal('modal-success');
        })
        .catch(function () {
          document.getElementById('modal-error-message').textContent =
            'Could not reach the server. Please try again in a moment.';
          showModal('modal-error');
        })
        .finally(function () {
          btn.textContent = originalText;
          btn.disabled = false;
        });
    });

    emailInput.addEventListener('input', function () {
      emailInput.classList.remove('input-error');
    });

    function isValidEmail(email) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    // ------- MODALS -------
    function showModal(id) {
      var overlay = document.getElementById(id);
      overlay.setAttribute('aria-hidden', 'false');
      overlay.classList.add('visible');
    }

    function hideModal(overlay) {
      overlay.setAttribute('aria-hidden', 'true');
      overlay.classList.remove('visible');
    }

    document.querySelectorAll('[data-dismiss="modal"]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        hideModal(btn.closest('.modal-overlay'));
      });
    });

    document.querySelectorAll('.modal-overlay').forEach(function (overlay) {
      overlay.addEventListener('click', function (e) {
        if (e.target === overlay) hideModal(overlay);
      });
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        document.querySelectorAll('.modal-overlay.visible').forEach(hideModal);
      }
    });

    // ------- SMOOTH SCROLL NAV -------
    document.querySelectorAll('a[href^="#"]').forEach(function (a) {
      a.addEventListener('click', function (e) {
        e.preventDefault();
        var target = document.querySelector(a.getAttribute('href'));
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      });
    });

    // ------- MODE SEGMENT + CARD SYNC -------
    var segmentBtns = document.querySelectorAll('.mode-segment-btn');
    var pill = document.querySelector('.mode-segment-pill');
    var track = document.querySelector('.mode-segment-track');
    var modeCards = document.querySelectorAll('.mode-card');
    var slides = document.querySelectorAll('.screenshot-slide');
    var clouds = document.querySelectorAll('.cloud');

    function movePill(index) {
      var btn = segmentBtns[index];
      var trackRect = track.getBoundingClientRect();
      var btnRect = btn.getBoundingClientRect();
      pill.style.left = (btnRect.left - trackRect.left) + 'px';
      pill.style.width = btnRect.width + 'px';
    }

    function setActiveMode(index) {
      movePill(index);
      segmentBtns.forEach(function (btn) {
        btn.classList.toggle('active', btn.getAttribute('data-index') === String(index));
      });
      modeCards.forEach(function (card) {
        card.classList.toggle('active', card.getAttribute('data-mode') === String(index));
      });
      slides.forEach(function (slide) {
        slide.classList.toggle('active', slide.getAttribute('data-slide') === String(index));
      });
      // Re-trigger cloud animations by removing and re-adding class
      clouds.forEach(function (cloud) {
        var isActive = cloud.getAttribute('data-cloud') === String(index);
        cloud.classList.remove('cloud-active');
        if (isActive) {
          // Force reflow to restart CSS animations
          void cloud.offsetWidth;
          cloud.classList.add('cloud-active');
        }
      });
    }

    // Position pill on load
    movePill(0);

    segmentBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        setActiveMode(parseInt(btn.getAttribute('data-index')));
      });
    });

    modeCards.forEach(function (card) {
      card.addEventListener('click', function () {
        setActiveMode(parseInt(card.getAttribute('data-mode')));
      });
    });

    // ------- MOBILE NAV TOGGLE -------
    var navToggle = document.querySelector('.nav-mobile-toggle');
    var navLinks = document.querySelector('.nav-links');
    navToggle.addEventListener('click', function () {
      navLinks.classList.toggle('open');
    });
  </script>
</body>
</html>

<style is:global>
  /* ============================================================
     RESET & BASE
     ============================================================ */
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    /* --- Neutrals (n8n primitives, pure gray HSL) --- */
    --neutral-white: hsl(0, 0%, 100%);
    --neutral-50:    hsl(0, 0%, 99%);
    --neutral-100:   hsl(0, 0%, 97.5%);
    --neutral-125:   hsl(0, 0%, 96%);
    --neutral-150:   hsl(0, 0%, 93%);
    --neutral-200:   hsl(0, 0%, 88%);
    --neutral-250:   hsl(0, 0%, 80%);
    --neutral-300:   hsl(0, 0%, 68%);
    --neutral-400:   hsl(0, 0%, 58%);
    --neutral-500:   hsl(0, 0%, 51%);
    --neutral-600:   hsl(0, 0%, 46%);
    --neutral-700:   hsl(0, 0%, 30%);
    --neutral-750:   hsl(0, 0%, 26%);
    --neutral-800:   hsl(0, 0%, 24%);
    --neutral-850:   hsl(0, 0%, 17%);
    --neutral-900:   hsl(0, 0%, 13%);
    --neutral-950:   hsl(0, 0%, 9%);

    /* --- Brand orange (n8n primary, hue 7) --- */
    --orange-300:    hsl(7, 100%, 68%);
    --orange-400:    hsl(7, 100%, 60%);
    --orange-alpha-10:  hsla(7, 100%, 68%, 0.1);
    --orange-alpha-35:  hsla(7, 100%, 68%, 0.35);

    /* --- Semantic: page surfaces (dark mode) --- */
    --page-bg:           var(--neutral-950);   /* 9%  — deepest */
    --section-alt-bg:    var(--neutral-900);   /* 13% — alternating sections */
    --surface-bg:        var(--neutral-850);   /* 17% — cards */
    --surface-raised-bg: var(--neutral-800);   /* 24% — hover, inputs */

    /* --- Semantic: text (dark mode) --- */
    --text-heading:   var(--neutral-125);  /* 96% */
    --text-body:      var(--neutral-250);  /* 80% */
    --text-muted:     var(--neutral-300);  /* 68% */
    --text-disabled:  var(--neutral-600);  /* 46% */

    /* --- Semantic: accent --- */
    --accent:         var(--orange-300);
    --accent-hover:   var(--orange-400);
    --accent-glow:    var(--orange-alpha-10);
    --accent-border:  var(--orange-alpha-35);

    /* --- Semantic: borders --- */
    --border-subtle:     rgba(255, 255, 255, 0.05);
    --border-default:    rgba(255, 255, 255, 0.1);

    /* --- Semantic: status --- */
    --success:        hsl(147, 60%, 50%);
    --success-bg:     hsla(147, 60%, 50%, 0.1);
    --error:          hsl(355, 83%, 60%);
    --error-bg:       hsla(355, 83%, 52%, 0.1);

    /* --- Layout --- */
    --max-width: 1120px;
    --section-py: 80px;
    --radius-sm: 8px;
    --radius-md: 12px;
    --radius-lg: 16px;
    --transition: 150ms ease;
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: var(--page-bg);
    color: var(--text-body);
    line-height: 1.6;
  }

  a { color: inherit; text-decoration: none; }
  button { cursor: pointer; border: none; font-family: inherit; }
  img { max-width: 100%; display: block; }

  /* ============================================================
     NAV
     ============================================================ */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: hsla(0, 0%, 9%, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-subtle);
