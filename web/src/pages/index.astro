    to   { margin-top: var(--drift); }
  }

  /* ============================================================
     MODES — segment + 3-column
     ============================================================ */
  .modes {
    background: var(--section-alt-bg);
    padding: var(--section-py) 24px;
  }

  .section-title {
    text-align: center;
    font-size: clamp(24px, 3.5vw, 32px);
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 32px;
