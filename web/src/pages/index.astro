  /* --- iOS-style pill segment --- */
  .mode-segment {
    display: flex;
    justify-content: center;
    margin-bottom: 32px;
  }

  .mode-segment-track {
    position: relative;
    display: inline-flex;
    background: var(--surface-bg);
    border: 1px solid var(--border-subtle);
    border-radius: 10px;
    padding: 4px;
  }

  .mode-segment-pill {
    position: absolute;
    top: 4px;
    height: calc(100% - 8px);
